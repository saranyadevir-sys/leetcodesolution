class Solution(object):
    def findMin(self, nums):
        low, high = 0, len(nums) - 1
        
        while low < high:
            mid = (low + high) // 2
            
            if nums[mid] < nums[high]:
                # Minimum is in the left half, mid could be the min
                high = mid
            elif nums[mid] > nums[high]:
                # Minimum is in the right half
                low = mid + 1
            else:
                # Duplicates found; shrink the search space one by one
                high -= 1
                
        return nums[low]
