class Solution(object):
    def generate(self, numRows):
        triangle = []

        for i in range(numRows):
            # Create a row of 1s (size i + 1)
            row = [1] * (i + 1)
            
            # Update the middle elements (from index 1 to i-1)
            # using the previous row in triangle
            for j in range(1, i):
                row[j] = triangle[i-1][j-1] + triangle[i-1][j]
            
            triangle.append(row)
            
        return triangle
