import math

class Solution(object):
    def getPermutation(self, n, k):
        """
        :type n: int
        :type k: int
        :rtype: str
        """
        # Create a list of numbers to use: [1, 2, 3, ..., n]
        numbers = [str(i) for i in range(1, n + 1)]
        
        # Convert k to 0-indexed for easier calculations
        k -= 1
        
        res = []
        # Precompute factorials or use math.factorial
        # We need (n-1)! for the first digit, (n-2)! for the second, etc.
        factorial = math.factorial(n - 1)
        
        for i in range(n - 1, -1, -1):
            # Determine the index of the number to pick
            idx = k // factorial
            res.append(numbers.pop(idx))
            
            # Update k for the next position
            k %= factorial
            
            # Update factorial for the next position: (i-1)!
            if i > 0:
                factorial //= i
                
        return "".join(res)
