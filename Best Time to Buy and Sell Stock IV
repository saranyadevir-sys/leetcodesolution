class Solution(object):
    def maxProfit(self, k, prices):
        if not prices or k == 0:
            return 0
        
        # Optimization: If k is large enough, treat as infinite transactions
        if k >= len(prices) // 2:
            return sum(max(prices[i+1] - prices[i], 0) for i in range(len(prices)-1))
        
        # buy[i] stores the min cost for i-th transaction
        # sell[i] stores the max profit for i-th transaction
        buy = [float('inf')] * (k + 1)
        sell = [0] * (k + 1)
        
        for price in prices:
            for i in range(1, k + 1):
                # Effective cost = current price - profit from previous sell
                buy[i] = min(buy[i], price - sell[i-1])
                # Profit = current price - effective cost
                sell[i] = max(sell[i], price - buy[i])
                
        return sell[k]
