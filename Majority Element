class Solution(object):
    def majorityElement(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        candidate = None
        count = 0

        for num in nums:
            # If count is 0, we pick the current number as the new candidate
            if count == 0:
                candidate = num
            
            # If the current number is our candidate, increment; else decrement
            count += (1 if num == candidate else -1)

        return candidate
