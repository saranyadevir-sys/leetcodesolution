class Solution(object):
    def solveNQueens(self, n):
        """
        :type n: int
        :rtype: List[List[str]]
        """
        res = []
        board = [["."] * n for _ in range(n)]
        
        # Tracking sets for restricted areas
        cols = set()
        posDiag = set() # (r + c)
        negDiag = set() # (r - c)
        
        def backtrack(r):
            # Base case: All queens placed
            if r == n:
                copy = ["".join(row) for row in board]
                res.append(copy)
                return
            
            for c in range(n):
                # Check if position is under attack
                if c in cols or (r + c) in posDiag or (r - c) in negDiag:
                    continue
                
                # "Choose" the position
                cols.add(c)
                posDiag.add(r + c)
                negDiag.add(r - c)
                board[r][c] = "Q"
                
                # "Explore" the next row
                backtrack(r + 1)
                
                # "Un-choose" (Backtrack)
                cols.remove(c)
                posDiag.remove(r + c)
                negDiag.remove(r - c)
                board[r][c] = "."
                
        backtrack(0)
        return res
