class Solution(object):
    def maxPathSum(self, root):
        # Initialize with a very small number since node values can be negative
        self.max_sum = float('-inf')
        
        def get_gain(node):
            if not node:
                return 0
            
            # Recursive calls to get max gain from left and right children
            # If a child's gain is negative, we ignore it (take 0)
            left_gain = max(get_gain(node.left), 0)
            right_gain = max(get_gain(node.right), 0)
            
            # Calculate path sum passing through the current node as the "highest" point
            current_path_sum = node.val + left_gain + right_gain
            
            # Update the global maximum sum found so far
            self.max_sum = max(self.max_sum, current_path_sum)
            
            # For the parent node, we can only return one branch to maintain a valid path
            return node.val + max(left_gain, right_gain)
            
        get_gain(root)
        return self.max_sum
