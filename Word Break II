class Solution(object):
    def wordBreak(self, s, wordDict):
        wordSet = set(wordDict)
        memo = {}

        def backtrack(current_s):
            # If we've already solved this substring, return the result
            if current_s in memo:
                return memo[current_s]
            if not current_s:
                return [""]

            res = []
            # Try every possible prefix
            for i in range(1, len(current_s) + 1):
                prefix = current_s[:i]
                if prefix in wordSet:
                    # Get all sentences possible from the remaining suffix
                    suffixes = backtrack(current_s[i:])
                    for suffix in suffixes:
                        # Combine prefix and suffix with a space
                        sentence = prefix + (" " + suffix if suffix else "")
                        res.append(sentence)
            
            memo[current_s] = res
            return res

        return backtrack(s)
