class Solution(object):
    def uniquePaths(self, m, n):
        # Create a 1D array representing one row of the grid
        # Initialize with 1 because there's only 1 way to reach any cell in the first row
        row = [1] * n
        
        # Iterate through the grid starting from the second row (index 1)
        for i in range(1, m):
            for j in range(1, n):
                # The value at row[j] is updated by adding the value to its left
                # Effectively: row[j] (new) = row[j] (above) + row[j-1] (left)
                row[j] += row[j-1]
        
        return row[-1]
