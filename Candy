class Solution(object):
    def candy(self, ratings):
        n = len(ratings)
        # Every child must have at least one candy
        candies = [1] * n
        
        # Left-to-Right: satisfy the left neighbor condition
        for i in range(1, n):
            if ratings[i] > ratings[i-1]:
                candies[i] = candies[i-1] + 1
        
        # Right-to-Left: satisfy the right neighbor condition
        for i in range(n - 2, -1, -1):
            if ratings[i] > ratings[i+1]:
                # We take the max to ensure the left-to-right condition remains met
                candies[i] = max(candies[i], candies[i+1] + 1)
        
        return sum(candies)
