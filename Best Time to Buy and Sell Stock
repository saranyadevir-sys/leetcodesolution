class Solution(object):
    def maxProfit(self, prices):
        min_price = float('inf')
        max_profit = 0
        
        for price in prices:
            # Update the lowest price found so far
            if price < min_price:
                min_price = price
            # Calculate potential profit and update max_profit
            elif price - min_price > max_profit:
                max_profit = price - min_price
                
        return max_profit
