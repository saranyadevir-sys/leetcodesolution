class Solution(object):
    def uniquePathsWithObstacles(self, obstacleGrid):
        m = len(obstacleGrid)
        n = len(obstacleGrid[0])
        
        # If the starting cell is an obstacle, no paths are possible
        if obstacleGrid[0][0] == 1:
            return 0
        
        # DP array initialized to 0
        dp = [0] * n
        dp[0] = 1 # Starting point
        
        for i in range(m):
            for j in range(n):
                if obstacleGrid[i][j] == 1:
                    # Obstacle found: no paths can pass through here
                    dp[j] = 0
                elif j > 0:
                    # Current paths = paths from above (dp[j]) + paths from left (dp[j-1])
                    dp[j] += dp[j-1]
                    
        return dp[-1]
