class Solution(object):
    def plusOne(self, digits):
        """
        :type digits: List[int]
        :rtype: List[int]
        """
        n = len(digits)
        
        # Traverse the array from the last digit to the first
        for i in range(n - 1, -1, -1):
            if digits[i] < 9:
                digits[i] += 1
                # No more carry needed, we can return early
                return digits
            
            # If the digit is 9, it becomes 0 and the loop continues
            digits[i] = 0
        
        # If the loop finishes, it means we had a carry-out from the most significant digit
        # e.g., [9, 9, 9] became [0, 0, 0], so we need to add a 1 at the beginning
        return [1] + digits
