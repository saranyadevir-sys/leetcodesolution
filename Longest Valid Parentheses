class Solution(object):
    def longestValidParentheses(self, s):
        """
        :type s: str
        :rtype: int
        """
        # Initialize stack with -1 to handle the base case for the first valid pair
        stack = [-1]
        max_length = 0
        
        for i, char in enumerate(s):
            if char == '(':
                # Push the index of the opening bracket
                stack.append(i)
            else:
                # Pop the last opening bracket or the last boundary
                stack.pop()
                
                if not stack:
                    # If stack is empty, this ')' is a new boundary/starting point
                    stack.append(i)
                else:
                    # Calculate length: current index minus index of the last element in stack
                    max_length = max(max_length, i - stack[-1])
        
        return max_length
