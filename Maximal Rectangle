class Solution(object):
    def maximalRectangle(self, matrix):
        """
        :type matrix: List[List[str]]
        :rtype: int
        """
        if not matrix or not matrix[0]:
            return 0
        
        cols = len(matrix[0])
        # heights array will store the height of '1's for the current row's histogram
        heights = [0] * (cols + 1) # +1 for a sentinel 0 to flush the stack
        max_area = 0
        
        for row in matrix:
            # 1. Update heights for the current row
            for i in range(cols):
                if row[i] == "1":
                    heights[i] += 1
                else:
                    heights[i] = 0
            
            # 2. Find the largest rectangle in the current row's histogram
            stack = [-1]
            for i in range(len(heights)):
                while heights[i] < heights[stack[-1]]:
                    h = heights[stack.pop()]
                    w = i - stack[-1] - 1
                    max_area = max(max_area, h * w)
                stack.append(i)
                
        return max_area
