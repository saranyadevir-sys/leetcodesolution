from collections import deque

class Solution(object):
    def maxSlidingWindow(self, nums, k):
        """
        :type nums: List[int]
        :type k: int
        :rtype: List[int]
        """
        res = []
        dq = deque() # Stores indices
        
        for i in range(len(nums)):
            # 1. Remove indices that are out of the current window range
            if dq and dq[0] < i - k + 1:
                dq.popleft()
            
            # 2. Remove indices of elements smaller than the current element
            # because they can't be the maximum anymore
            while dq and nums[dq[-1]] < nums[i]:
                dq.pop()
            
            dq.append(i)
            
            # 3. Once the first window is complete, start adding to results
            if i >= k - 1:
                res.append(nums[dq[0]])
                
        return res
