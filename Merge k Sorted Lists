import heapq

class Solution(object):
    def mergeKLists(self, lists):
        # Min-heap to keep track of the smallest current elements
        min_heap = []
        
        # Initial push: the head of each linked list
        for i, l in enumerate(lists):
            if l:
                # Store (value, index, node) to handle tie-breaking
                heapq.heappush(min_heap, (l.val, i, l))
        
        dummy = ListNode(0)
        current = dummy
        
        while min_heap:
            val, i, node = heapq.heappop(min_heap)
            
            # Attach the smallest node to our result list
            current.next = node
            current = current.next
            
            # If the extracted node has a next, push it into the heap
            if node.next:
                heapq.heappush(min_heap, (node.next.val, i, node.next))
                
        return dummy.next
