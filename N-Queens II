class Solution(object):
    def totalNQueens(self, n):
        """
        :type n: int
        :rtype: int
        """
        def backtrack(row, cols, pos_diagonals, neg_diagonals):
            if row == n:
                return 1
            
            count = 0
            # A queen at (row, col) attacks:
            # 1. Column: col
            # 2. Positive Diagonal: (row + col)
            # 3. Negative Diagonal: (row - col)
            
            for col in range(n):
                pos_diag = row + col
                neg_diag = row - col
                
                if (col in cols or 
                    pos_diag in pos_diagonals or 
                    neg_diag in neg_diagonals):
                    continue
                
                # Add current positions to sets
                cols.add(col)
                pos_diagonals.add(pos_diag)
                neg_diagonals.add(neg_diag)
                
                # Explore next row
                count += backtrack(row + 1, cols, pos_diagonals, neg_diagonals)
                
                # Backtrack: remove positions from sets
                cols.remove(col)
                pos_diagonals.remove(pos_diag)
                neg_diagonals.remove(neg_diag)
                
            return count

        return backtrack(0, set(), set(), set())
