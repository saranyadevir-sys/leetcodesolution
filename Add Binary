class Solution(object):
    def addBinary(self, a, b):
        """
        :type a: str
        :type b: str
        :rtype: str
        """
        res = []
        carry = 0
        i, j = len(a) - 1, len(b) - 1
        
        while i >= 0 or j >= 0 or carry:
            # Get the digit from string 'a' or 0 if pointer is out of bounds
            val_a = int(a[i]) if i >= 0 else 0
            # Get the digit from string 'b' or 0 if pointer is out of bounds
            val_b = int(b[j]) if j >= 0 else 0
            
            # Calculate sum of digits and carry
            total = val_a + val_b + carry
            # The bit to append is total % 2 (0 or 1)
            res.append(str(total % 2))
            # The new carry is total // 2
            carry = total // 2
            
            i -= 1
            j -= 1
            
        # Reverse the result list and join into a string
        return "".join(res[::-1])
