class Solution(object):
    def calculate(self, s):
        """
        :type s: str
        :rtype: int
        """
        stack = []
        current_num = 0
        result = 0
        sign = 1 # 1 represents '+', -1 represents '-'

        for char in s:
            if char.isdigit():
                # Build the multi-digit number
                current_num = current_num * 10 + int(char)
            elif char == '+':
                # Add the completed number to our result
                result += sign * current_num
                sign = 1
                current_num = 0
            elif char == '-':
                # Subtract the completed number from our result
                result += sign * current_num
                sign = -1
                current_num = 0
            elif char == '(':
                # Push the current result and sign to the stack to process later
                stack.append(result)
                stack.append(sign)
                # Reset for the expression inside the parenthesis
                result = 0
                sign = 1
            elif char == ')':
                # Add the last number inside the parenthesis to the internal result
                result += sign * current_num
                current_num = 0
                # Multiply by the sign before '(' and add to the result before '('
                result *= stack.pop() # The sign
                result += stack.pop() # The previous result
                
        # Catch the last number if there wasn't a trailing operator or parenthesis
        return result + (sign * current_num)
